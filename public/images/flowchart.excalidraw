      "link": null,
      "locked": false,
      "text": "Step 1: Enable Clock to Port M\n\nRegister: SYSCTL_RCGCGPIO\n\nAddress: 0x400FE608\n\nAction: Set bit 11 (0x800) to enable\nclock for Port M",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "Mrz-pQFXSQuEeLHHcIMEf",
      "originalText": "Step 1: Enable Clock to Port M\n\nRegister: SYSCTL_RCGCGPIO\n\nAddress: 0x400FE608\n\nAction: Set bit 11 (0x800) to enable clock for Port M",
      "autoResize": true,
      "lineHeight": 1.25
    },
